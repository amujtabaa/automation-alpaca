# Alpaca paper trading credentials — PAPER ONLY, never live keys.
# Get these from: https://app.alpaca.markets -> Paper account -> API Keys
ALPACA_PAPER_API_KEY=your-paper-key-here
ALPACA_PAPER_API_SECRET=your-paper-secret-here

# Broker adapter selection: auto | mock | alpaca
#   auto   -> Alpaca paper adapter when the keys above are set, else the mock
#   mock   -> in-memory mock broker (no network); default-safe for dev/CI
#   alpaca -> always the Alpaca paper adapter (requires the keys above)
BROKER_ADAPTER=auto

# Optional — monitoring cadence and unfilled-order timeout
ALPACA_POLL_CADENCE_SECONDS=15
ALPACA_UNFILLED_TIMEOUT_MINUTES=60

# Market data feed selection (Phase 5) — reuses the SAME paper keys above,
# no separate credential needed: auto | mock | alpaca
MARKET_DATA_FEED=auto
MARKET_DATA_STALE_MINUTES=5

# Strategy Engine (Phase 5) — first strategy's thresholds; sizing is a fixed
# placeholder pending Phase 6 CAPI, not real risk management.
ENABLE_STRATEGY_ENGINE=true
STRATEGY_DECISION_CADENCE_SECONDS=5
STRATEGY_MOMENTUM_THRESHOLD_PCT=3.0
STRATEGY_MIN_VOLUME=50000
STRATEGY_MAX_SPREAD_PCT=1.0
STRATEGY_LIMIT_BUFFER_PCT=0.1
STRATEGY_DEFAULT_QUANTITY=10

# Copy this file to .env (which is gitignored) and fill in real paper keys.
# Never commit .env — it holds credentials that must stay off version control.
