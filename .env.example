# Copy this file to .env (gitignored). Leave credentials blank for mock/paper-dev;
# never commit .env or place live-trading credentials in this repository.

# Backend store: sqlite (durable default) or memory (tests only).
STATE_STORE=sqlite
# SQLite file used when STATE_STORE=sqlite.
ALPACA_DB_PATH=./data/app.db
# Mock candidate-injection routes; use true only for credential-free local development.
ENABLE_DEV_ROUTES=true

# Alpaca Paper credential; blank keeps BROKER_ADAPTER=auto on the mock adapter.
ALPACA_PAPER_API_KEY=
# Alpaca Paper secret; blank keeps BROKER_ADAPTER=auto on the mock adapter.
ALPACA_PAPER_API_SECRET=
# Broker adapter: auto (mock without both paper keys), mock, or paper-only alpaca.
BROKER_ADAPTER=auto
# Seconds between monitoring ticks; must be positive.
ALPACA_POLL_CADENCE_SECONDS=15
# Minutes before an open order is surfaced as stale; zero surfaces immediately.
ALPACA_UNFILLED_TIMEOUT_MINUTES=60
# Consecutive stale-SUBMITTING re-drive attempts before durable needs-review escalation.
STALE_SUBMITTING_MAX_REDRIVE_ATTEMPTS=10
# Targeted queries allowed for TIMEOUT_QUARANTINE before escalation or resolution.
TIMEOUT_QUARANTINE_MAX_QUERY_ATTEMPTS=3
# Start the background monitoring loop.
ENABLE_MONITORING=true

# Run the acting runtime reconciliation on monitoring ticks.
RECONCILIATION_ENABLED=true
# Milliseconds in which an order is recent for reconciliation handling.
RECONCILE_RECENT_THRESHOLD_MS=5000
# Fractional average-price tolerance for reconciliation parity.
RECONCILE_AVG_PRICE_TOLERANCE=0.0001
# Missing-open checks required before a not-found conclusion.
RECONCILE_OPEN_CHECK_MISSING_RETRIES=3
# Maximum reconciliation queries per minute.
RECONCILE_QUERY_BUDGET_PER_MIN=200
# Seconds to wait before reconciliation starts at application startup.
RECONCILE_STARTUP_DELAY_SECS=10

# Market-data feed: auto (mock without paper keys), mock, or alpaca.
MARKET_DATA_FEED=auto
# Minutes before a market-data snapshot is stale; must be positive.
MARKET_DATA_STALE_MINUTES=5
# Start the background candidate strategy loop.
ENABLE_STRATEGY_ENGINE=true
# Seconds between strategy decisions; must be positive.
STRATEGY_DECISION_CADENCE_SECONDS=5
# Momentum threshold percentage for the initial strategy.
STRATEGY_MOMENTUM_THRESHOLD_PCT=3.0
# Minimum reported volume for the initial strategy.
STRATEGY_MIN_VOLUME=50000
# Maximum spread percentage; use a large value, not zero, to effectively disable.
STRATEGY_MAX_SPREAD_PCT=1.0
# Limit-price buffer percentage for the initial strategy.
STRATEGY_LIMIT_BUFFER_PCT=0.1
# Candidate quantity from the initial strategy; must be a positive integer.
STRATEGY_DEFAULT_QUANTITY=10

# Keep the read-only market-data tape recorder off unless deliberately collecting a corpus.
ENABLE_TAPE_RECORDER=false
# NDJSON tape output path; the recorder owns this file, not execution state.
TAPE_RECORDER_PATH=./data/tapes/tape.ndjson
# Comma-separated symbols; required when ENABLE_TAPE_RECORDER=true.
TAPE_RECORDER_SYMBOLS=
# Seconds between tape samples; must be positive.
TAPE_RECORDER_INTERVAL_SECONDS=1
# Maximum bytes per tape segment before rotation.
TAPE_RECORDER_MAX_BYTES=52428800
# Number of rotated tape segments to retain; must be positive.
TAPE_RECORDER_MAX_SEGMENTS=7

# CAPI per-order share cap; must be positive and gates rather than resizes orders.
CAPI_MAX_SHARES_PER_ORDER=500
# CAPI per-order notional cap; must be positive.
CAPI_MAX_NOTIONAL_PER_ORDER=5000
# CAPI total local-derived exposure cap; must be positive.
CAPI_MAX_TOTAL_EXPOSURE=25000
# Optional comma-separated ticker allowlist; blank means no extra restriction.
CAPI_TRADING_ALLOWLIST=

# Keep beta sell-side protection enabled.
PROTECTION_ENABLED=true
# Fraction below average cost for the protective stop; 0.08 means 8 percent.
PROTECTION_STOP_LOSS_PCT=0.08
# Protective limit buffer fraction; 0.005 means 0.5 percent.
PROTECTION_LIMIT_BUFFER_PCT=0.005
# Optional dedicated protection cadence; blank uses the monitoring tick.
PROTECTION_CADENCE_SECONDS=
