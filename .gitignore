# Python
__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
.eggs/

# Pytest temp basetemp + agent ad-hoc scratch. Test runs pass repo-relative
# basetemp/db paths (e.g. .pytest-tmp-wo0113-scope-1, .pytest-cache-r2-*), one
# per run/shard/probe. Wildcards so uniquely-named dirs cannot accumulate in the
# root or be swept into a commit (the .agents/.codex leak class, 06abd3f).
.pytest_tmp*/
.pytest-tmp*/
.pytest-cache*/
.pytest-run*/
.pytest-agent*/
.pytest-subagent*/
.pytest-audit*/
.pytest-chaos*/
.pytest-r2*/
.pytest_cache/
.hostile-closure/

# Tool caches (regenerable in CI; never committed)
.mypy_cache/
.ruff_cache/
.grimp_cache/
.import_linter_cache/
.hypothesis/

# Secondary review virtualenv (mirror of .venv for the review seat)
.venv-review/

# Coverage artifacts (measured in CI; not committed)
.coverage
.coverage.*
htmlcov/
coverage.xml

# SQLite database (created at runtime, not committed)
data/
*.db
*.sqlite
*.sqlite3

# Credentials / environment
.env
.env.local

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Claude Code local/personal files (not shared with the team)
CLAUDE.local.md
.claude/settings.local.json
# Transient git worktrees created by background workflows (auto-cleaned; never a deliverable)
.claude/worktrees/

# Per-session agent tooling that lives in the execution environment, NOT repo
# content (a leaked plugin/skill library was accidentally committed once — 06abd3f,
# dropped 2026-07-18). These dirs mirror .claude/ but for other agent seats.
.agents/
.codex/
